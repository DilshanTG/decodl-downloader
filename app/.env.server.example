# StockMart.lk — Environment Variables
# Copy this file to .env.server and fill in real values.
# Run: wasp start db (in one terminal), then wasp start (in another)
# DATABASE_URL= (set automatically by wasp db start — leave commented)

# Admin emails (comma-separated — these get admin dashboard access on signup)
ADMIN_EMAILS=you@example.com

# ─── Decodl API (stock media download engine) ────────────────────────────────
# Get from your Decodl dashboard at decodl.ir
DECODL_APP_KEY=your_decodl_app_key
DECODL_TOKEN=your_decodl_bearer_token

# ─── DigiMart Payment Gateway (pay.digimartsolutions.lk) ─────────────────────
PAYHERE_MERCHANT_KEY=sk_live_your_merchant_api_key
PAYHERE_MERCHANT_ID=sk_live_your_merchant_api_key
PAYHERE_MERCHANT_SECRET=your_hmac_secret_key
PAYHERE_NOTIFY_URL=https://your-app.fly.dev/payhere-webhook
PAYHERE_RETURN_URL=https://your-app.fly.dev/dashboard?payment=success
PAYHERE_CANCEL_URL=https://your-app.fly.dev/pricing

# ─── SendGrid (transactional email — configure before going live) ─────────────
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
